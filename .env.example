# Copy to .env to override defaults. `docker compose up` works with no .env at all.

# Data source for the initial load:
#   synthetic -> offline, biologically-plausible generated subset (default)
#   gdc       -> pull a small real subset from the public GDC API
DATA_SOURCE=synthetic

# Only used when DATA_SOURCE=gdc
GDC_CASES_PER_TYPE=60
GDC_EXPR_SAMPLES=40
